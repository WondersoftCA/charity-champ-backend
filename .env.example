# Copy this file to .env and fill in your values
# Never commit .env to version control

# From https://dashboard.stripe.com/apikeys  (use sk_live_... for production)
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# From https://dashboard.stripe.com/apikeys  (use pk_live_... for production)
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY_HERE

# From https://dashboard.stripe.com/webhooks  (after you register the endpoint)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Random secret used to sign JWT tokens — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-here

# Comma-separated list of allowed web origins (leave blank to allow all, lock down in production)
# ALLOWED_ORIGINS=https://your-website.com,https://www.your-website.com

# Port the server listens on (hosting platforms often set this automatically)
PORT=3000
